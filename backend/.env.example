# Database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key
SUPABASE_ANON=your-supabase-anon-key

# External APIs
# Musixmatch: https://developer.musixmatch.com/signup — free tier only returns
# lyric previews; full lyrics require Musixmatch's own commercial license and
# their approval for this specific app. Don't enable ENABLE_LICENSED_LYRICS_PROVIDERS
# below unless you've actually secured that.
MUSIXMATCH_API_KEY=your-musixmatch-key

# AI APIs (Optional - Phase 4)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Feature Flags
ENABLE_AI_FALLBACK=false
MAX_AI_CALLS_PER_SONG=3

# Licensed lyrics providers (Musixmatch) are OFF by default per the legal
# architecture doc: never rely on licensed lyrics DBs as the default/primary source.
# Only enable this on a self-hosted instance where you've confirmed your own
# license terms permit it. When off, /process (without manual lyrics) and
# /lyrics/fetch return 403 — use the ASR strategy instead (requires the user to
# upload their own audio/video file; there's no server-side YouTube audio
# download at all — see backend/app/song_processing/youtube.py's module docstring).
ENABLE_LICENSED_LYRICS_PROVIDERS=false

# Development
DEBUG=true
LOG_LEVEL=INFO
