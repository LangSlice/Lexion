# YouTube Data API v3 key (used server-side only, by server/api/youtube/search.get.ts —
# never shipped to the browser). Get one at https://console.cloud.google.com/apis/credentials
# — you must enable "YouTube Data API v3" on the project first.
NUXT_YOUTUBE_API_KEY=your-youtube-data-api-key

# Backend API base URL
NUXT_PUBLIC_API_BASE=http://localhost:8000/api
